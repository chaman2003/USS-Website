---
import BaseLayout from '../layouts/BaseLayout.astro';
import GlowField from '../components/fx/GlowField.astro';
import { metaDescription } from '../lib/seo/meta';

const title = 'Search';
const description = metaDescription([
  'Search Unity Software Solution for blog posts, services, case studies, and company pages.',
  'Find AI, web dev, and startup insights from USS, a Bengaluru software studio serving India and global clients.',
]);
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Search', path: '/search' },
];
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} robots="noindex, follow">
  <section class="grain relative overflow-hidden border-b border-[var(--color-surface-line)]">
    <GlowField variant="subtle" />
    <div class="relative mx-auto max-w-3xl px-5 py-16 sm:px-8">
      <h1 class="font-display text-4xl font-semibold">Search</h1>
      <p class="mt-3 text-[var(--color-text-secondary)]">Find articles, services, and pages across our site.</p>
      <form class="mt-8" role="search" id="search-form">
        <label for="search-input" class="sr-only">Search query</label>
        <input
          id="search-input"
          name="q"
          type="search"
          placeholder="Search…"
          autocomplete="off"
          class="w-full rounded-[var(--radius-card)] border border-[var(--color-surface-line)] bg-[var(--color-surface-card)] px-4 py-3 text-[var(--color-text-primary)] outline-none focus:border-[var(--color-brand-gold)]/50"
        />
      </form>
      <div id="search-results" class="mt-8 space-y-4" aria-live="polite"></div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  async function loadPagefind() {
    return new Promise((resolve, reject) => {
      if (window.__pagefind) {
        resolve(window.__pagefind);
        return;
      }
      const script = document.createElement('script');
      script.src = '/pagefind/pagefind.js';
      script.type = 'module';
      script.onload = async () => {
        try {
          const pagefind = await import('/pagefind/pagefind.js');
          window.__pagefind = pagefind;
          resolve(pagefind);
        } catch (e) {
          reject(e);
        }
      };
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  async function initSearch() {
    const params = new URLSearchParams(window.location.search);
    const query = params.get('q') ?? '';
    const input = document.getElementById('search-input');
    const resultsEl = document.getElementById('search-results');
    if (!input || !resultsEl) return;

    input.value = query;
    if (!query.trim()) return;

    try {
      const pagefind = await loadPagefind();
      await pagefind.init();
      const search = await pagefind.search(query);
      const items = await Promise.all(search.results.slice(0, 12).map((r) => r.data()));

      if (items.length === 0) {
        resultsEl.innerHTML = '<p class="text-[var(--color-text-muted)]">No results found.</p>';
        return;
      }

      resultsEl.innerHTML = items
        .map(
          (item) =>
            '<article class="rounded-[var(--radius-card)] border border-[var(--color-surface-line)] bg-[var(--color-surface-card)] p-4">' +
            '<h2 class="font-display text-lg font-semibold">' +
            '<a href="' + item.url + '" class="hover:text-[var(--color-text-gold)]">' + (item.meta?.title || item.url) + '</a>' +
            '</h2>' +
            (item.excerpt ? '<p class="mt-2 text-sm text-[var(--color-text-secondary)]">' + item.excerpt + '</p>' : '') +
            '</article>',
        )
        .join('');
    } catch {
      resultsEl.innerHTML =
        '<p class="text-[var(--color-text-muted)]">Search is available after build. Use preview mode to test Pagefind.</p>';
    }
  }

  document.getElementById('search-form')?.addEventListener('submit', function (e) {
    e.preventDefault();
    const input = document.getElementById('search-input');
    const q = input && input.value ? input.value.trim() : '';
    if (q) {
      const url = new URL(window.location.href);
      url.searchParams.set('q', q);
      window.location.href = url.toString();
    }
  });

  initSearch();
  document.addEventListener('astro:page-load', initSearch);
</script>

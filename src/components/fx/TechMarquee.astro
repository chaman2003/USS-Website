---
/*
 * Infinite, dual-row tech-logo marquee. Hand-authored inline SVGs (simplified,
 * monochrome, currentColor) so they adapt to the theme and need zero network.
 * Decorative → aria-hidden. Pauses on hover; static under reduced-motion.
 */
const techs = [
  'react', 'nextdotjs', 'typescript', 'nodedotjs', 'python', 'docker',
  'kubernetes', 'amazonaws', 'mongodb', 'postgresql', 'tailwindcss', 'astro',
  'flutter', 'openai', 'redis', 'graphql',
] as const;

// Simplified single-path glyphs (geometric impressions, not official marks).
const ICON: Record<string, string> = {
  react: 'M12 9.8a2.2 2.2 0 1 0 0 4.4 2.2 2.2 0 0 0 0-4.4ZM12 6c4.4 0 8 1.8 8 4s-3.6 4-8 4-8-1.8-8-4 3.6-4 8-4Z M8.5 7C10.7 3.2 13.3 1.4 14.5 2.5s.5 4.3-1.7 8-4.8 6-6 4.9.5-4.4 1.7-8.4Z M8.5 17c-2.2-3.8-3-7.4-1.7-8.4s3.8.9 6 4.9-.5 6.9-1.7 8-3.8-.7-2.6-4.5Z',
  nextdotjs: 'M12 2a10 10 0 1 0 5.6 18.3L8 8v8H6V6h2.5l9 12.8A10 10 0 0 0 12 2Z M15.5 8h2v6h-2z',
  typescript: 'M3 3h18v18H3V3Z M13 11.5h4M15 11.5V18 M7 12h4M9 12v6',
  nodedotjs: 'M12 2 3 7v10l9 5 9-5V7l-9-5Z M9 9v6c0 1 .8 1.5 2 1.5s2-.6 2-1.8',
  python: 'M12 2c-3 0-3 2-3 2v2h6v1H6s-3 0-3 4 3 4 3 4h2v-2s0-3 3-3h4s2 0 2-2V4s0-2-5-2Z M8.5 4.5a.8.8 0 1 1 0 .1Z M12 22c3 0 3-2 3-2v-2H9v-1h6s3 0 3-4-3-4-3-4h-2v2s0 3-3 3H6s-2 0-2 2v4s0 2 5 2Z',
  docker: 'M4 11h3v3H4zM8 11h3v3H8zM12 11h3v3h-3zM8 7h3v3H8zM12 7h3v3h-3zM16 7h3v3h-3z M2 14h18c0 3-2 6-7 6-6 0-8-4-9-6Z',
  kubernetes: 'M12 2 3 7v10l9 5 9-5V7l-9-5Z M12 8v8M8 10l8 4M16 10l-8 4',
  amazonaws: 'M4 14c5 3 11 3 16 0 M5 16c4 2 10 2 14 0 M7 7l2 6 2-4 2 4 2-6',
  mongodb: 'M12 2c2 4 5 7 5 11s-3 7-5 9c-2-2-5-5-5-9s3-7 5-11Z M12 4v17',
  postgresql: 'M7 4c4-1 8-1 11 1 2 4 1 11-3 14-1 1-3 1-4 0M9 6c-2 3-2 9 0 13M13 6v9',
  tailwindcss: 'M6 11c1-3 3-4 5-3 1.5.7 1.7 2 3.5 2.5 1.3.4 2.5 0 3.5-1.2-1 3-3 4-5 3-1.5-.7-1.7-2-3.5-2.5C11.7 11.4 10.5 11.8 9.5 13c-1.3.4-2.5 0-3.5-2Z M2 16c1-3 3-4 5-3 1.5.7 1.7 2 3.5 2.5',
  astro: 'M12 2 7 19l5-3 5 3L12 2Z M9.5 16c0 2 1 3 2.5 3s2.5-1 2.5-3',
  flutter: 'M13 2 4 11l3 3 12-12h-6ZM13 11l-5 5 5 5h6l-5-5 5-5h-6Z',
  openai: 'M12 2a5 5 0 0 1 4.9 6 5 5 0 0 1-1 9.5A5 5 0 0 1 7.1 16 5 5 0 0 1 8 6.5 5 5 0 0 1 12 2Z M12 8v8M8.5 10l7 4M15.5 10l-7 4',
  redis: 'M3 7l9-3 9 3-9 3-9-3Z M3 12l9 3 9-3M3 17l9 3 9-3',
  graphql: 'M12 3 4 8v8l8 5 8-5V8l-8-5Z M12 3v18M4 8l16 8M20 8 4 16',
};

const labels: Record<string, string> = {
  react: 'React', nextdotjs: 'Next.js', typescript: 'TypeScript', nodedotjs: 'Node.js',
  python: 'Python', docker: 'Docker', kubernetes: 'Kubernetes', amazonaws: 'AWS',
  mongodb: 'MongoDB', postgresql: 'PostgreSQL', tailwindcss: 'Tailwind', astro: 'Astro',
  flutter: 'Flutter', openai: 'OpenAI', redis: 'Redis', graphql: 'GraphQL',
};

// Each row uses the FULL list so a single copy always exceeds the viewport
// width - that's what keeps the -50% loop seamless with no gap. Row B runs the
// list reversed for visual variety while scrolling the opposite direction.
const rowA = techs;
const rowB = [...techs].reverse();
---

<div class="marquee-mask group/m relative flex flex-col gap-4 overflow-hidden" aria-hidden="true">
  <div class="animate-marquee flex w-max shrink-0 group-hover/m:[animation-play-state:paused]">
    {
      [...rowA, ...rowA].map((t) => (
        <span class="mr-3 flex shrink-0 items-center gap-2.5 rounded-[var(--radius-pill)] border border-[var(--color-surface-line)] bg-[var(--color-surface-card)] px-5 py-2.5 text-[var(--color-text-secondary)] shadow-[var(--shadow-card)] transition-colors hover:text-[var(--color-text-gold)]">
          <svg class="h-5 w-5 text-[var(--color-brand-gold)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d={ICON[t]} />
          </svg>
          <span class="font-mono text-sm">{labels[t]}</span>
        </span>
      ))
    }
  </div>
  <div class="animate-marquee-reverse flex w-max shrink-0 group-hover/m:[animation-play-state:paused]">
    {
      [...rowB, ...rowB].map((t) => (
        <span class="mr-3 flex shrink-0 items-center gap-2.5 rounded-[var(--radius-pill)] border border-[var(--color-surface-line)] bg-[var(--color-surface-card)] px-5 py-2.5 text-[var(--color-text-secondary)] shadow-[var(--shadow-card)] transition-colors hover:text-[var(--color-text-gold)]">
          <svg class="h-5 w-5 text-[var(--color-brand-gold)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d={ICON[t]} />
          </svg>
          <span class="font-mono text-sm">{labels[t]}</span>
        </span>
      ))
    }
  </div>
</div>

---
/*
 * Ambient gold glow orbs + optional film grain. Glow colours pull from the
 * theme-aware --glow-* vars so they read correctly in both light and dark.
 * Purely decorative, aria-hidden, disabled under reduced-motion via CSS.
 */
interface Props {
  variant?: 'hero' | 'section' | 'subtle';
  grain?: boolean;
  grid?: boolean;
  class?: string;
}

const { variant = 'section', grain = true, grid = false, class: className = '' } = Astro.props;
---

<div class={`pointer-events-none absolute inset-0 overflow-hidden ${className}`} aria-hidden="true">
  {grid && <div class="bg-grid absolute inset-0 opacity-60 [mask-image:radial-gradient(ellipse_at_center,#000_30%,transparent_75%)]" />}

  {
    variant === 'hero' && (
      <>
        <div
          class="animate-aurora absolute -top-1/3 left-1/2 h-[70vh] w-[70vh] -translate-x-1/2 rounded-full blur-[100px]"
          style="background: radial-gradient(circle, var(--glow-1), transparent 60%);"
          data-parallax="0.15"
        />
        <div
          class="animate-float absolute top-1/4 -left-20 h-[40vh] w-[40vh] rounded-full blur-[90px]"
          style="background: radial-gradient(circle, var(--glow-2), transparent 60%); animation-delay: -4s;"
          data-parallax="0.25"
        />
        <div
          class="animate-float absolute -bottom-24 right-0 h-[45vh] w-[45vh] rounded-full blur-[100px]"
          style="background: radial-gradient(circle, var(--glow-3), transparent 60%); animation-delay: -8s;"
          data-parallax="0.1"
        />
      </>
    )
  }
  {
    variant === 'section' && (
      <>
        <div
          class="animate-float absolute -top-32 right-0 h-80 w-80 rounded-full blur-[90px]"
          style="background: radial-gradient(circle, var(--glow-2), transparent 65%);"
        />
        <div
          class="animate-float absolute -bottom-40 -left-20 h-96 w-96 rounded-full blur-[110px]"
          style="background: radial-gradient(circle, var(--glow-3), transparent 65%); animation-delay: -6s;"
        />
      </>
    )
  }
  {
    variant === 'subtle' && (
      <div
        class="absolute left-1/2 top-1/2 h-96 w-[60%] -translate-x-1/2 -translate-y-1/2 rounded-full blur-[120px]"
        style="background: radial-gradient(ellipse, var(--glow-3), transparent 70%);"
      />
    )
  }

  {grain && <div class="grain-overlay" />}
</div>

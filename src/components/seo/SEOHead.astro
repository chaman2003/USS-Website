---
import { cleanCanonicalUrl } from '../../lib/seo/canonical';
import { isPreviewDeploy } from '../../lib/seo/site';

interface Props {
  title?: string;
  description: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalUrl?: string;
  robots?: string;
  titleTemplate?: boolean;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleTags?: string[];
  keywords?: string;
  maxImagePreview?: boolean;
}

const siteUrl = import.meta.env.SITE;
const {
  title,
  description,
  ogType = 'website',
  ogImage,
  ogImageAlt,
  canonicalUrl,
  robots,
  titleTemplate = true,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleTags = [],
  keywords,
  maxImagePreview = false,
} = Astro.props;

const fullTitle = title
  ? titleTemplate
    ? `${title} | Unity Software Solution`
    : title
  : 'Unity Software Solution (USS) | Software Studio, Bengaluru';

const resolvedOgImage = ogImage
  ? new URL(ogImage, siteUrl).href
  : new URL('/og-default.jpg', siteUrl).href;
const resolvedCanonical = canonicalUrl ?? cleanCanonicalUrl(Astro.url);
const resolvedRobots =
  robots ?? (isPreviewDeploy() ? 'noindex, nofollow' : maxImagePreview ? 'index, follow, max-image-preview:large' : 'index, follow');
const resolvedOgImageAlt = ogImageAlt ?? fullTitle;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
{keywords && <meta name="keywords" content={keywords} />}
<meta name="robots" content={resolvedRobots} />
<link rel="canonical" href={resolvedCanonical} />

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:type" content={ogType} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:alt" content={resolvedOgImageAlt} />
<meta property="og:site_name" content="Unity Software Solution" />
<meta property="og:locale" content="en_IN" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />
<meta name="twitter:image:alt" content={resolvedOgImageAlt} />

{
  articlePublishedTime && (
    <meta property="article:published_time" content={articlePublishedTime} />
  )
}
{
  articleModifiedTime && (
    <meta property="article:modified_time" content={articleModifiedTime} />
  )
}
{articleAuthor && <meta property="article:author" content={articleAuthor} />}
{
  articleTags.map((tag) => <meta property="article:tag" content={tag} />)
}

<link rel="alternate" type="application/rss+xml" title="Unity Software Solution Blog" href="/rss.xml" />
<link rel="alternate" type="application/atom+xml" title="Unity Software Solution Blog" href="/atom.xml" />
<link rel="alternate" type="application/feed+json" title="Unity Software Solution Blog" href="/feed.json" />

---
interface Props {
  phrases: string[];
  slug: string;
  heading?: string;
  count?: number;
}

import { relatedSearchLine } from '../../lib/seo/keywords';

const { phrases, slug, heading = 'People also search for', count = 8 } = Astro.props;
const line = relatedSearchLine(phrases, slug, count);
---

{
  line && (
    <aside class="reveal mt-12 border-t border-[var(--color-surface-line)] pt-8" aria-label={heading}>
      <h2 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">{heading}</h2>
      <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-secondary)]">{line}</p>
    </aside>
  )
}

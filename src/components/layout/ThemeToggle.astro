---
// Light/dark theme toggle. Default theme is light; selection persists in
// localStorage. The no-flash script in BaseLayout applies the class pre-paint.
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle colour theme"
  title="Toggle light/dark"
  class="group relative inline-flex h-9 w-9 items-center justify-center rounded-full border border-[var(--color-surface-line)] text-[var(--color-text-secondary)] transition-colors hover:border-[var(--color-brand-gold)]/50 hover:text-[var(--color-brand-gold)]"
>
  <!-- Sun (shown in dark mode → click for light) -->
  <svg
    class="absolute h-[18px] w-[18px] scale-0 opacity-0 transition-all duration-300 dark:scale-100 dark:opacity-100"
    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
  </svg>
  <!-- Moon (shown in light mode → click for dark) -->
  <svg
    class="absolute h-[18px] w-[18px] scale-100 opacity-100 transition-all duration-300 dark:scale-0 dark:opacity-0"
    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
  </svg>
</button>

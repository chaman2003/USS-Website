---
import Logo from './Logo.astro';

const linkGroups = [
  {
    heading: 'Company',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Services', href: '/services' },
      { label: 'Work', href: '/work' },
      { label: 'Careers', href: '/careers' },
    ],
  },
  {
    heading: 'Resources',
    links: [
      { label: 'Blog', href: '/blog' },
      { label: 'FAQ', href: '/faq' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Privacy Policy', href: '/privacy-policy' },
      { label: 'Terms & Conditions', href: '/terms-and-conditions' },
    ],
  },
];

const year = 2026;
---

<footer class="relative overflow-hidden border-t border-[var(--color-surface-line)] bg-[var(--color-surface-sunken)] text-[var(--color-text-primary)]">
  <div class="bg-dots absolute inset-0 opacity-30" aria-hidden="true"></div>
  <!-- ambient glow -->
  <div
    class="pointer-events-none absolute -top-32 left-1/2 h-64 w-[80%] -translate-x-1/2 rounded-full blur-[120px]"
    style="background: radial-gradient(ellipse, var(--glow-3), transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-[1400px] px-5 py-12 sm:px-8 sm:py-16">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1fr_1fr]">
      <!-- Brand + tagline + social -->
      <div>
        <Logo />
        <p class="mt-4 max-w-xs font-display text-base italic text-[var(--color-text-secondary)] sm:text-lg">
          Building Scalable, Secure &amp; Intelligent Software.
        </p>
        <p class="mt-5 text-sm text-[var(--color-text-secondary)]">Bengaluru, Karnataka, India</p>
        <div class="mt-4 flex items-center gap-3">
          <a
            href="https://www.instagram.com/unitysoftwaresolutionuss_25/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Unity Software Solution on Instagram"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-surface-line)] text-[var(--color-text-secondary)] transition-all duration-300 hover:border-[var(--color-brand-gold)]/50 hover:text-[var(--color-text-gold)] hover:shadow-[var(--shadow-glow-sm)]"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s0 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.2 15.6 2.2 15.2 2.2 12s0-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.4 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.15 0-3.52.01-4.76.07-.9.04-1.39.2-1.71.32-.43.17-.74.37-1.06.69-.32.32-.52.63-.69 1.06-.13.32-.28.81-.32 1.71C3.4 8.49 3.4 8.86 3.4 12s.01 3.51.07 4.75c.04.9.2 1.39.32 1.71.17.43.37.74.69 1.06.32.32.63.52 1.06.69.32.13.81.28 1.71.32 1.24.06 1.61.07 4.76.07s3.52-.01 4.76-.07c.9-.04 1.39-.2 1.71-.32.43-.17.74-.37 1.06-.69.32-.32.52-.63.69-1.06.13-.32.28-.81.32-1.71.06-1.24.07-1.61.07-4.75s-.01-3.52-.07-4.76c-.04-.9-.2-1.39-.32-1.71a2.85 2.85 0 0 0-.69-1.06 2.85 2.85 0 0 0-1.06-.69c-.32-.13-.81-.28-1.71-.32C15.52 4.01 15.15 4 12 4Zm0 3.06A4.94 4.94 0 1 1 12 16.94 4.94 4.94 0 0 1 12 7.06Zm0 1.8a3.14 3.14 0 1 0 0 6.28 3.14 3.14 0 0 0 0-6.28Zm5.14-.66a1.15 1.15 0 1 1-2.3 0 1.15 1.15 0 0 1 2.3 0Z"></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/company/unity-software-solution/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Unity Software Solution on LinkedIn"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-surface-line)] text-[var(--color-text-secondary)] transition-all duration-300 hover:border-[var(--color-brand-gold)]/50 hover:text-[var(--color-text-gold)] hover:shadow-[var(--shadow-glow-sm)]"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.74v20.5C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.76V1.74C24 .78 23.2 0 22.22 0Z"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link groups: 3 columns on phone, rejoin parent grid on desktop -->
      <div class="grid grid-cols-3 gap-x-4 gap-y-8 md:contents">
        {
          linkGroups.map((group) => (
            <nav aria-label={group.heading}>
              <h2 class="eyebrow">{group.heading}</h2>
              <ul class="mt-4 space-y-2 text-sm">
                {group.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="group inline-flex items-center gap-1.5 text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-gold)]"
                    >
                      <span class="hidden h-px w-0 bg-[var(--color-brand-gold-light)] transition-all duration-300 group-hover:w-3 sm:inline-block" aria-hidden="true" />
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          ))
        }
      </div>
    </div>

    <div class="mt-10 border-t border-[var(--color-surface-line)] pt-6 text-center font-mono text-xs text-[var(--color-text-muted)] sm:mt-12">
      &copy; {year} Unity Software Solution. All rights reserved.
    </div>
  </div>
</footer>

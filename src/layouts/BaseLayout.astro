---
import SEOHead from '../components/seo/SEOHead.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import SkipLink from '../components/layout/SkipLink.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CookieConsent from '../components/ui/CookieConsent.astro';
import { buildPageGraph } from '../lib/seo/schema';
import type { BreadcrumbItem } from '../lib/seo/schema';
import { cleanCanonicalUrl } from '../lib/seo/canonical';
import '../styles/fonts.css';
import '../styles/global.css';
import '../styles/typography.css';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalUrl?: string;
  robots?: string;
  titleTemplate?: boolean;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleTags?: string[];
  keywords?: string;
  maxImagePreview?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  schemaExtra?: Record<string, unknown>[];
}

const {
  title,
  description,
  ogType,
  ogImage,
  ogImageAlt,
  canonicalUrl,
  robots,
  titleTemplate,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleTags,
  keywords,
  maxImagePreview,
  breadcrumbs = [{ name: 'Home', path: '/' }],
  schemaExtra = [],
} = Astro.props;

const pageUrl = canonicalUrl ?? cleanCanonicalUrl(Astro.url);
const pageGraph = buildPageGraph({
  breadcrumbs,
  page: { url: pageUrl, name: title, description },
  extra: schemaExtra,
});

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
---

<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#08080a" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="preload" href="/logo-opt.webp" as="image" type="image/webp" />
    <link rel="manifest" href="/manifest.webmanifest" />

    {
      gscVerification && (
        <meta name="google-site-verification" content={gscVerification} />
      )
    }

    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('uss-theme');
          if (saved === 'light') document.documentElement.classList.remove('dark');
          else document.documentElement.classList.add('dark');
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <SEOHead
      title={title}
      description={description}
      ogType={ogType}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      canonicalUrl={canonicalUrl}
      robots={robots}
      titleTemplate={titleTemplate}
      articlePublishedTime={articlePublishedTime}
      articleModifiedTime={articleModifiedTime}
      articleAuthor={articleAuthor}
      articleTags={articleTags}
      keywords={keywords}
      maxImagePreview={maxImagePreview}
    />

    <JsonLd data={pageGraph} />
    <slot name="head" />

    <script type="speculationrules" is:inline>
      {
        "prerender": [
          {
            "where": { "href_matches": "/blog/*" },
            "eagerness": "moderate"
          }
        ]
      }
    </script>

    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
          filter: none !important;
        }
        .word-rise > span {
          opacity: 1 !important;
          animation: none !important;
        }
      </style>
    </noscript>
  </head>
  <body class="bg-[var(--color-surface-base)] text-[var(--color-text-primary)] antialiased">
    <div class="scroll-progress"></div>
    <SkipLink />
    <Header />
    <main id="main-content" data-pagefind-body>
      <slot />
    </main>
    <Footer />
    <CookieConsent gaId={gaId} />

    <script>
      import '../scripts/theme.ts';
      import '../scripts/motion.ts';
      import '../scripts/web-vitals.ts';
    </script>
  </body>
</html>

---
import SEOHead from '../components/seo/SEOHead.astro';
import SkipLink from '../components/layout/SkipLink.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';
import '../styles/typography.css';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { title, description, ogType, ogImage, canonicalUrl } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#08080a" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" href="/logo-opt.png" />
    <link rel="preload" href="/logo-opt.webp" as="image" />

    <!-- No-flash theme: apply saved preference before first paint. Default DARK. -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('uss-theme');
          if (saved === 'light') document.documentElement.classList.remove('dark');
          else document.documentElement.classList.add('dark');
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- media="print" loads the stylesheet without blocking render; onload switches it to screen -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      />
    </noscript>

    <SEOHead
      title={title}
      description={description}
      ogType={ogType}
      ogImage={ogImage}
      canonicalUrl={canonicalUrl}
    />

    <!-- Page-specific head content, e.g. JSON-LD structured data. -->
    <slot name="head" />

    <noscript>
      <style>
        /* Without JS the IntersectionObserver never fires - show all content. */
        .reveal {
          opacity: 1 !important;
          transform: none !important;
          filter: none !important;
        }
        .word-rise > span {
          opacity: 1 !important;
          animation: none !important;
        }
      </style>
    </noscript>
  </head>
  <body class="bg-[var(--color-surface-base)] text-[var(--color-text-primary)] antialiased">
    <div class="scroll-progress"></div>
    <SkipLink />
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      import '../scripts/motion.ts';
    </script>
  </body>
</html>

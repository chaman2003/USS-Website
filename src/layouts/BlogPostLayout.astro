---
import BaseLayout from './BaseLayout.astro';
import GlowField from '../components/fx/GlowField.astro';
import ClosingCTA from '../components/ui/ClosingCTA.astro';
import Button from '../components/ui/Button.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  tags: string[];
  ogImage?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, author, tags, ogImage, headings = [] } = Astro.props;

const toc = headings.filter((h) => h.depth === 2);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
const formattedDate = dateFormatter.format(pubDate);
const isoDate = pubDate.toISOString();

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  author: { '@type': 'Organization', name: author },
  datePublished: isoDate,
  url: Astro.url.href,
  publisher: {
    '@type': 'Organization',
    name: 'Unity Software Solution',
  },
};
---

<BaseLayout title={title} description={description} ogType="article" ogImage={ogImage}>
  <article class="relative">
    <!-- Header band with ambient glow -->
    <header class="grain relative overflow-hidden border-b border-[var(--color-surface-line)]">
      <GlowField variant="subtle" />
      <div class="relative mx-auto max-w-4xl px-5 pb-12 pt-16 sm:px-8">
        <a
          href="/blog"
          class="group inline-flex items-center gap-1.5 font-mono text-sm text-[var(--color-text-gold)] transition-colors hover:text-[var(--color-brand-gold-bright)]"
        >
          <span class="transition-transform group-hover:-translate-x-1" aria-hidden="true">←</span>
          Back to Blog
        </a>
        <h1 class="reveal mt-5 font-display text-4xl font-semibold leading-[1.1] text-[var(--color-text-primary)] sm:text-5xl">
          {title}
        </h1>
        <div class="reveal mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 font-mono text-sm text-[var(--color-text-muted)]">
          <span>{author}</span>
          <span aria-hidden="true" class="text-[var(--color-brand-gold)]/50">/</span>
          <time datetime={isoDate}>{formattedDate}</time>
        </div>
        {
          tags.length > 0 && (
            <ul class="reveal mt-5 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <li class="rounded-[var(--radius-pill)] border border-[var(--color-surface-line)] px-3 py-1 font-mono text-xs text-[var(--color-text-secondary)]">
                  {tag}
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    <div class="mx-auto max-w-[1400px] px-5 py-14 sm:px-8">
      <div class="lg:grid lg:grid-cols-[240px_1fr] lg:gap-16">
        <!-- Sticky table of contents -->
        {
          toc.length > 0 && (
            <aside class="hidden lg:block">
              <nav aria-label="On this page" class="sticky top-28">
                <p class="eyebrow mb-4">On this page</p>
                <ul class="space-y-1">
                  {toc.map((h) => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        data-spy-link
                        class="block border-l-2 border-[var(--color-surface-line)] py-1.5 pl-4 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text-primary)] data-[active=true]:border-[var(--color-brand-gold)] data-[active=true]:text-[var(--color-text-gold)]"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </aside>
          )
        }

        <div class="min-w-0">
          <div class="reveal rich-text">
            <slot />
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- CTA -->
  <ClosingCTA>
    <h2 class="reveal font-display text-4xl font-semibold sm:text-5xl">
      Enjoyed this <span class="text-gold-gradient">piece?</span>
    </h2>
    <p class="reveal mx-auto mt-4 max-w-xl text-[var(--color-text-secondary)]">
      Let's talk about how USS can help with your next project.
    </p>
    <div class="reveal mt-8">
      <span class="inline-block"><Button href="/contact" variant="primary" size="lg" magnetic>Start a Project →</Button></span>
    </div>
  </ClosingCTA>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
</BaseLayout>

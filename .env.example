# Contact form submission endpoint (Formspree).
# Only PUBLIC_-prefixed variables are exposed to the browser in Astro.
# The Formspree endpoint is public by design (spam protection via honeypot + reCAPTCHA).
PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Alternative: if using Resend instead of Formspree (server-side only, do NOT prefix with PUBLIC_)
# RESEND_API_KEY=re_xxxxxxxxxxxx
